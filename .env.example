# Chronovista Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# YouTube OAuth Credentials (REQUIRED)
# =============================================================================
# Obtain these from the Google Cloud Console:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Desktop application)
# 3. Copy the Client ID and Client Secret below
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# YouTube Data API v3 key (used for public data queries — optional when OAuth is configured)
YOUTUBE_API_KEY=your_youtube_api_key_here

# =============================================================================
# Database Configuration (Optional — defaults work for Docker setup)
# =============================================================================
# These are used by docker-compose.yml for the PostgreSQL container.
# Change them if you want a custom database username/password.
DB_USER=chronovista
DB_PASSWORD=chronovista

# Full database URLs (auto-constructed by docker-compose.yml from DB_USER/DB_PASSWORD;
# only set these manually if you are connecting to an external database)
# DATABASE_URL=postgresql+asyncpg://chronovista:chronovista@db:5432/chronovista
# DATABASE_DEV_URL=postgresql+asyncpg://dev_user:dev_password@localhost:5434/chronovista_dev
# DATABASE_INTEGRATION_URL=postgresql+asyncpg://dev_user:dev_password@localhost:5434/chronovista_integration_test

# =============================================================================
# Application Configuration (Optional)
# =============================================================================
# Port to expose the application on the host machine.
# Change this if 8765 conflicts with another service.
APP_PORT=8765

# Frontend port (served separately in development mode)
CHRONOVISTA_FRONTEND_PORT=8766

# Include NLP dependencies in the Docker image (increases image size by ~2GB).
# Set to "true" to enable spaCy, keyBERT, and transformers-based features.
# Leave as "false" for faster builds and smaller images.
INCLUDE_NLP=false

# =============================================================================
# Application Behaviour (Optional)
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=chronovista

# Serve the React frontend as static files from the backend (set automatically
# by docker-compose.yml — only override if running without Docker)
# SERVE_STATIC=true

# OAuth redirect URI (used during the browser-based login flow)
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly,https://www.googleapis.com/auth/youtube.force-ssl

# =============================================================================
# Storage Paths (Optional)
# =============================================================================
DATA_DIR=./data
CACHE_DIR=./cache
LOGS_DIR=./logs
EXPORT_DIR=./exports

# =============================================================================
# NLP Configuration (Optional — only relevant when INCLUDE_NLP=true)
# =============================================================================
NLP_MODEL=en_core_web_sm
NLP_BATCH_SIZE=100
TAG_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Performance Tuning (Optional)
# =============================================================================
API_RATE_LIMIT=100
CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
RETRY_BACKOFF=2
